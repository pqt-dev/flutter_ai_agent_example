# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Fix undefined GGML symbols on ARM64:
    # 1. Add GGML_CPU_GENERIC to use generic fallback implementations
    # 2. Exclude arch/arm/ files to avoid duplicate symbol conflicts
    if target.name == 'whisper_ggml_plus'
      target.build_configurations.each do |config|
        config.build_settings['OTHER_CFLAGS'] ||= '$(inherited)'
        config.build_settings['OTHER_CFLAGS'] += ' -DGGML_CPU_GENERIC'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= '$(inherited)'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] += ' -DGGML_CPU_GENERIC'

        # Disable Metal on simulator — the medium model (~1.5GB) exceeds
        # the simulator's Metal buffer allocation limit, causing crash.
        # -UGGML_USE_METAL undoes the -DGGML_USE_METAL=1 from the podspec.
        config.build_settings['OTHER_CFLAGS[sdk=iphonesimulator*]'] =
          '$(inherited) -DGGML_CPU_GENERIC -UGGML_USE_METAL'
        config.build_settings['OTHER_CPLUSPLUSFLAGS[sdk=iphonesimulator*]'] =
          '$(inherited) -DGGML_CPU_GENERIC -UGGML_USE_METAL'
      end

      # Remove arch/arm source files to prevent duplicate symbols
      target.source_build_phase.files.to_a.each do |file|
        if file.file_ref&.real_path&.to_s&.include?('arch/arm/')
          target.source_build_phase.remove_file_reference(file.file_ref)
        end
      end
    end
  end
end
